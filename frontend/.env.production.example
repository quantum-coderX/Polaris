# ── Vercel Frontend Environment Variables ─────────────────────────────────────
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# (or use the Vercel CLI: vercel env add VITE_API_URL)

# ── Render Service URLs ───────────────────────────────────────────────────────
VITE_CORE_API_URL=https://polaris-core.onrender.com
VITE_AUTH_API_URL=https://polaris-auth.onrender.com
VITE_PAYMENT_API_URL=https://polaris-payment.onrender.com
VITE_NOTIF_API_URL=https://polaris-notif.onrender.com

# WebSocket base URL — points to the core service on Render
VITE_WS_URL=wss://polaris-core.onrender.com

# Stripe publishable key (safe to expose in frontend)
VITE_STRIPE_PK=pk_test_YOUR_PUBLISHABLE_KEY_HERE

